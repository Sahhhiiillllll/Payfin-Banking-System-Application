{
  "name": "payfin",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "api:dev": "cd api && DATABASE_URL=postgresql+pg8000://payfin:payfin@localhost:5432/payfin python3 run_local.py",
    "legacy:dev": "python3 app.py",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "DATABASE_URL=postgresql+pg8000://payfin:payfin@localhost:5432/payfin alembic upgrade head",
    "db:seed": "cd api && DATABASE_URL=postgresql+pg8000://payfin:payfin@localhost:5432/payfin python3 -c \"from app_factory import init_db; init_db()\"",
    "dev:all": "npm run db:up && sleep 3 && npm run db:migrate && npm run db:seed && concurrently \"npm run api:dev\" \"npm run dev\""
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.468.0",
    "pusher-js": "^8.4.0",
    "framer-motion": "^11.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
