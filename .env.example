# ═══════════════════════════════════════════════════════════════════════════════
# Payfin — Production Environment Configuration
# Copy to .env.local (Next.js) and set in Vercel Project Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32-minimum-64-chars-recommended
FLASK_ENV=production
FLASK_DEBUG=False
NODE_ENV=production

# ── JWT / Session ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-separate-jwt-secret-openssl-rand-hex-32
JWT_EXPIRY_HOURS=24

# ── PostgreSQL (Neon / Supabase / RDS) ────────────────────────────────────────
# Direct connection (migrations, admin):
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/payfin?sslmode=require
# Pooled connection (serverless API — use pgbouncer port 6543 or Neon pooler):
DATABASE_POOL_URL=postgresql+psycopg://user:password@ep-xxx-pooler.region.aws.neon.tech/payfin?sslmode=require

# ── Redis / Upstash (rate limiting + optional idempotency cache) ──────────────
REDIS_URL=rediss://default:token@xxx.upstash.io:6379
RATELIMIT_STORAGE_URI=rediss://default:token@xxx.upstash.io:6379

# ── CORS & Frontend ───────────────────────────────────────────────────────────
CORS_ORIGINS=https://payfin.vercel.app,http://localhost:3000
FRONTEND_URL=https://payfin.vercel.app
NEXT_PUBLIC_API_URL=

# ── Realtime (Pusher — serverless-friendly WebSocket alternative) ─────────────
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=ap2

# ── Supabase Realtime (alternative to Pusher) ─────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── MFA / Webhooks ────────────────────────────────────────────────────────────
MFA_ISSUER=Payfin
WEBHOOK_SECRET=generate-webhook-hmac-secret-openssl-rand-hex-32
IDEMPOTENCY_TTL_SECONDS=86400

# ── Payment Aggregators ───────────────────────────────────────────────────────
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret
STRIPE_SECRET_KEY=sk_live_xxxxxxxx

# ── External Verification APIs ────────────────────────────────────────────────
RAZORPAY_IFSC_API=https://ifsc.razorpay.com
NPCI_VPA_VERIFY_URL=

# ── Branding ──────────────────────────────────────────────────────────────────
COMPANY_NAME=Payfin
APP_NAME=Payfin
UPI_SUFFIX=payfin

# ── Vercel Build ──────────────────────────────────────────────────────────────
INIT_DB_ON_STARTUP=false
